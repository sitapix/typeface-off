{
  "name": "skeleton-playground",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --plugin-search-dir . --check .",
    "format": "prettier --write --plugin prettier-plugin-svelte --plugin prettier-plugin-tailwindcss ."
  },
  "devDependencies": {
    "@skeletonlabs/skeleton": "^4.15.0",
    "@skeletonlabs/skeleton-svelte": "^4.12.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.61.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.0.0",
    "canvas-confetti": "^1.9.0",
    "prettier": "^3.3.0",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.0",
    "svelte-check": "^4.5.0",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.4.1",
    "typescript": "^5.8.0",
    "vite": "^8.0.0"
  },
  "type": "module"
}
