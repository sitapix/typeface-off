{
  "name": "coding-font-sveltekit",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "fonts:generate": "node scripts/generate-fonts.cjs",
    "fonts:local": "node scripts/generate-local-fonts.cjs",
    "fonts:names": "node scripts/list-font-names.cjs",
    "fonts:all": "npm run fonts:generate && npm run fonts:local && npm run fonts:names",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "devDependencies": {
    "@skeletonlabs/skeleton": "^4.15.0",
    "@skeletonlabs/skeleton-svelte": "^4.12.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.61.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/fontkit": "^2.0.9",
    "@types/node": "^22.0.0",
    "canvas-confetti": "^1.9.0",
    "fontkit": "^2.0.4",
    "prettier": "^3.3.0",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.0",
    "svelte-check": "^4.5.0",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.4.1",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  },
  "type": "module",
  "dependencies": {
    "@tiptap/core": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@zumer/snapdom": "^2.12.2",
    "shiki": "^4.2.0"
  }
}
